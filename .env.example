# Chave da API Groq (gratis) para gerar artigos
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Chave da API Tavily para pesquisa na internet (grátis: 1.000 buscas/mês)
# Obtenha em: https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# Cookies de sessao do Mercado Livre (base64) para gerar links de afiliado
# Gere com: Get-Content ml_cookies.json -Raw | %{ [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes($_)) }
ML_COOKIES_B64=base64_encoded_cookies...

# Credenciais do app Mercado Livre (client_credentials) para consultar a API de Produtos
# Obtenha em: https://developers.mercadolivre.com.br/
ML_CLIENT_ID=your_client_id
ML_CLIENT_SECRET=your_client_secret

---
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const artigos = Object.entries(import.meta.glob("../../content/artigos/*.md", { eager: true }));

  return artigos.map(([path, mod]) => ({
    params: { slug: path.split("/").pop()?.replace(".md", "") },
    props: { frontmatter: mod.frontmatter, Content: mod.Content },
  }));
}

const { frontmatter, Content } = Astro.props;
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");

const todosArtigos = Object.entries(import.meta.glob("../../content/artigos/*.md", { eager: true }))
  .map(([path, mod]) => ({
    slug: path.split("/").pop()?.replace(".md", "") || "",
    title: mod.frontmatter.title,
    pubDate: mod.frontmatter.pubDate,
    category: mod.frontmatter.category,
    image: mod.frontmatter.image,
  }))
  .sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());

const relacionados = todosArtigos.filter((a) => a.slug !== Astro.params.slug).slice(0, 3);

  const readingTime = Math.max(1, Math.ceil(Content ? 1 : (frontmatter.description || "").split(" ").length / 200));

const categories = [
  { name: "Notícias", slug: "noticia", icon: "sports_esports" },
  { name: "Reviews", slug: "review", icon: "grade" },
  { name: "Guias", slug: "guia", icon: "memory" },
  { name: "Promoções", slug: "promocao", icon: "trophy" },
  { name: "Listas", slug: "lista", icon: "menu_book" },
];
---

<Layout
  title={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.image}
  pubDate={frontmatter.pubDate}
  tags={frontmatter.tags}
  category={frontmatter.category}
>
  <div class="fixed top-0 left-0 w-full h-[3px] z-50" id="readingProgress">
    <div id="readingProgressBar" class="h-full bg-[#2ff801] shadow-[0_0_8px_rgba(47,248,1,0.5)] w-0 transition-[width] duration-150 ease-out"></div>
  </div>

  <div class="relative z-10 pt-[100px] pb-xxl px-gutter">
    <div class="max-w-[1100px] mx-auto grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-xl">
      <article class="max-w-max-content-width mx-auto w-full" id="articleContent">
        {frontmatter.image && (
          <div class="rounded-xl overflow-hidden mb-xl shadow-2xl group">
            <img
              src={frontmatter.image}
              alt={frontmatter.title}
              class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-700"
              fetchpriority="high"
              decoding="async"
            />
          </div>
        )}

        <div class="flex flex-wrap gap-sm mb-md">
          {frontmatter.category && (
            <span class="px-sm py-1 bg-primary/10 text-primary border border-primary/20 rounded-full font-label text-label uppercase tracking-widest">
              {frontmatter.category}
            </span>
          )}
          {frontmatter.tags?.slice(0, 3).map((tag) => (
            <span class="px-sm py-1 bg-primary/10 text-primary border border-primary/20 rounded-full font-label text-label uppercase tracking-widest">
              {tag}
            </span>
          ))}
        </div>

        <h1 class="font-h1 text-h1 text-white mb-md leading-tight">
          {frontmatter.title}
        </h1>

        <div class="flex items-center gap-md mb-xl text-outline font-label text-label">
          <div class="flex items-center gap-xs">
            <span class="material-symbols-outlined text-[18px]">person</span>
            <span>BLOG GAMER</span>
          </div>
          <div class="w-1 h-1 bg-outline-variant/40 rounded-full" />
          <div class="flex items-center gap-xs">
            <span class="material-symbols-outlined text-[18px]">calendar_today</span>
            <span>{new Date(frontmatter.pubDate).toLocaleDateString("pt-BR")}</span>
          </div>
          <div class="w-1 h-1 bg-outline-variant/40 rounded-full" />
          <span>{readingTime} MIN DE LEITURA</span>
        </div>

        <div class="font-body text-body text-on-surface-variant space-y-lg leading-relaxed" id="articleBody">
          {frontmatter.description && (
            <p class="first-letter:text-5xl first-letter:font-black first-letter:text-primary first-letter:mr-3 first-letter:float-left">
              {frontmatter.description}
            </p>
          )}
          <Content />
        </div>

        <div class="mt-xl pt-xl border-t border-white/10">
          <div class="flex flex-wrap gap-sm items-center">
            <span class="text-outline font-label text-label mr-md self-center">TAGS:</span>
            {frontmatter.tags?.map((tag) => (
              <a
                href={`${base}?tag=${tag}`}
                class="px-md py-1 rounded-full border border-primary/30 text-primary bg-primary/5 hover:bg-primary/10 transition-colors font-label text-label no-underline hover:no-underline"
              >
                {tag.toUpperCase()}
              </a>
            ))}
          </div>
        </div>

        <a
          href="https://t.me/+TRWZ67WHuk85Y2Nh"
          target="_blank"
          rel="noopener noreferrer"
          class="block my-xl rounded-lg overflow-hidden card-depth no-underline hover:no-underline"
        >
          <img
            src={`${base}images/banner-grupo.png`}
            alt="Grupo VIP Telegram - Ofertas Gamer Diárias"
            class="w-full h-auto"
            loading="lazy"
            decoding="async"
          />
        </a>

        <div class="mt-xl p-lg bg-surface-container rounded-xl border border-outline-variant/10 text-center">
          <p class="text-on-surface-variant text-xs mb-sm">
            Gostou do conteúdo? Compartilhe com outros gamers!
          </p>
          <p class="text-on-surface-variant/60 text-[10px] mb-md">
            Links de afiliado ajudam a manter o blog.
          </p>
          <a
            href={base}
            class="inline-flex items-center gap-sm px-lg py-md rounded-lg border border-outline-variant/20 text-on-surface-variant hover:text-primary hover:border-primary transition-colors font-label text-label no-underline hover:no-underline"
          >
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            VOLTAR AO INÍCIO
          </a>
        </div>
      </article>

      <aside class="space-y-xl hidden lg:block" id="articleSidebar">
        <a
          href="https://t.me/+TRWZ67WHuk85Y2Nh"
          target="_blank"
          rel="noopener noreferrer"
          class="block rounded-lg overflow-hidden card-depth no-underline hover:no-underline"
        >
          <img
            src={`${base}images/banner-grupo-9x16-2.png`}
            alt="Grupo VIP Telegram - Ofertas Gamer Diárias"
            class="w-full h-auto"
            loading="lazy"
            decoding="async"
          />
        </a>

        <section>
          <h3 class="font-label text-label text-primary uppercase tracking-widest mb-lg flex items-center gap-sm">
            <span class="w-8 h-[1px] bg-primary" />
            CATEGORIAS
          </h3>
          <ul class="space-y-sm">
            {categories.map((cat) => (
              <li>
                <a
                  href={`${base}categoria/${cat.slug}/`}
                  class="btn-depth flex justify-between items-center p-md group no-underline hover:no-underline"
                >
                  <span class="flex items-center gap-sm text-on-surface group-hover:text-primary transition-colors text-sm">
                    <span class="material-symbols-outlined text-sm">{cat.icon}</span>
                    {cat.name}
                  </span>
                  <span class="bg-surface-container-highest px-2 py-0.5 rounded text-xs text-on-surface-variant">
                    {todosArtigos.filter((a) => a.category === cat.slug).length}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section>
          <h3 class="font-label text-label text-primary uppercase tracking-widest mb-lg flex items-center gap-sm">
            <span class="w-8 h-[1px] bg-primary" />
            ARTIGOS RELACIONADOS
          </h3>
          <div class="space-y-lg">
            {relacionados.slice(0, 3).map((artigo) => (
              <a href={`${base}blog/${artigo.slug}/`} class="card-depth block overflow-hidden group no-underline hover:no-underline">
                <div class="relative aspect-[16/9] overflow-hidden">
                  {artigo.image ? (
                    <img
                      src={artigo.image}
                      alt={artigo.title}
                      class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="w-full h-full bg-surface-container-high flex items-center justify-center text-2xl">
                      🎮
                    </div>
                  )}
                </div>
                <div class="p-3">
                  <h4 class="text-sm font-semibold text-on-surface group-hover:text-primary transition-colors line-clamp-2">
                    {artigo.title}
                  </h4>
                </div>
              </a>
            ))}
          </div>
        </section>

        <section class="p-lg card-depth relative overflow-hidden text-center">
          <h3 class="text-lg font-bold text-[#2ff801] mb-sm">Ofertas Gamer</h3>
          <p class="text-xs text-on-surface-variant mb-md">
            Entre no grupo VIP do Telegram e receba ofertas diárias.
          </p>
          <a
            href="https://t.me/+TRWZ67WHuk85Y2Nh"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-xs px-lg py-sm bg-[#2ff801] text-black font-label text-[10px] uppercase font-bold rounded-md hover:shadow-[0_0_12px_rgba(47,248,1,0.4)] transition-all no-underline"
          >
            Entrar no Grupo
          </a>
        </section>
      </aside>
    </div>
  </div>

  <script>
    const progressBar = document.getElementById("readingProgressBar");
    if (progressBar) {
      window.addEventListener("scroll", () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
        progressBar.style.width = progress + "%";
      }, { passive: true });
    }

    const observerOptions = { threshold: 0, rootMargin: "0px 0px 200px 0px" };
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("opacity-100", "translate-y-0");
          entry.target.classList.remove("opacity-0", "translate-y-10");
        }
      });
    }, observerOptions);

    const viewportHeight = window.innerHeight;
    document.querySelectorAll("#articleContent > *, #articleSidebar > section").forEach((el) => {
      const rect = el.getBoundingClientRect();
      if (rect.top < viewportHeight + 100) {
        el.classList.add("opacity-100", "translate-y-0");
      } else {
        el.classList.add("transition-all", "duration-700", "opacity-0", "translate-y-10");
        observer.observe(el);
      }
    });


  </script>

  <style is:global>
    /* === Article Game Images === */
    #articleBody .article-game-img {
      width: 100%;
      max-width: 400px;
      aspect-ratio: 16 / 9;
      object-fit: cover;
      border-radius: var(--radius-md, 10px);
      border: 1px solid var(--border, #1C1C2E);
      display: block;
      margin: 0.5rem 0 0.75rem 0;
    }
    /* === Product Cards === */
    #articleBody .product-card {
      background: var(--bg-card, #0A0A0F);
      border: 1px solid var(--border, #1C1C2E);
      border-radius: var(--radius-lg, 14px);
      overflow: hidden;
      margin-bottom: 1.75rem;
      transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }
    #articleBody .product-card:hover {
      border-color: var(--accent, #A855F7);
      box-shadow: 0 0 24px rgba(168, 85, 247, 0.1);
    }
    #articleBody .product-card-img {
      width: 100%;
      aspect-ratio: 16 / 9;
      object-fit: cover;
      display: block;
      border-radius: 0;
    }
    #articleBody .product-card-body {
      padding: 1.25rem;
    }
    #articleBody .product-card-body h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text-primary, #efecfb);
      margin: 0 0 0.5rem 0;
      line-height: 1.3;
    }
    #articleBody .product-price {
      color: var(--accent, #A855F7);
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
    }
    #articleBody .product-desc {
      color: var(--text-secondary, #aca9b7);
      line-height: 1.7;
      margin-bottom: 1rem;
      font-size: 0.95rem;
    }
    #articleBody .product-pros {
      margin-bottom: 0.5rem;
      padding: 0.75rem 1rem;
      background: rgba(47, 248, 1, 0.04);
      border-left: 3px solid #2ff801;
      border-radius: 0 8px 8px 0;
      font-size: 0.9rem;
      color: var(--text-secondary, #aca9b7);
      line-height: 1.7;
    }
    #articleBody .product-pros strong {
      color: #2ff801;
    }
    #articleBody .product-cons {
      margin-bottom: 0.5rem;
      padding: 0.75rem 1rem;
      background: rgba(239, 68, 68, 0.04);
      border-left: 3px solid #ef4444;
      border-radius: 0 8px 8px 0;
      font-size: 0.9rem;
      color: var(--text-secondary, #aca9b7);
      line-height: 1.7;
    }
    #articleBody .product-cons strong {
      color: #ef4444;
    }
    #articleBody .product-btn {
      display: block;
      width: 100%;
      padding: 0.875rem 1.5rem;
      background: #2ff801;
      color: #000;
      font-family: var(--font-label, "Public Sans", sans-serif);
      font-size: 0.8125rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      text-align: center;
      border-radius: 10px;
      text-decoration: none;
      transition: all 0.3s ease;
      margin-top: 1rem;
      border: none;
      cursor: pointer;
    }
    #articleBody .product-btn:hover {
      box-shadow: 0 0 20px rgba(47, 248, 1, 0.4);
      transform: scale(1.02);
      color: #000;
      text-decoration: none;
    }
    #articleBody .product-btn:active {
      transform: scale(0.98);
    }

    /* === Tabela Comparativa === */
    #articleBody table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      margin: 1.5rem 0;
      font-size: 0.875rem;
      border-radius: var(--radius, 10px);
      overflow: hidden;
      border: 1px solid var(--border, #1C1C2E);
    }
    #articleBody th {
      background: var(--bg-elevated, #12121D);
      color: var(--accent, #A855F7);
      font-weight: 700;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      padding: 0.75rem 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border, #1C1C2E);
    }
    #articleBody td {
      padding: 0.75rem 1rem;
      color: var(--text-secondary, #aca9b7);
      border-bottom: 1px solid var(--border, #1C1C2E);
    }
    #articleBody tr:last-child td {
      border-bottom: none;
    }
    #articleBody tr:hover td {
      background: rgba(168, 85, 247, 0.04);
    }

    /* === FAQ === */
    #articleBody h3:has(+ ul):has(+ ol) {
      /* FAQ headings that are followed by lists */
    }
    #articleBody h3 strong {
      color: var(--accent, #A855F7);
    }
    #articleBody ul:has(strong) {
      padding-left: 0;
      list-style: none;
    }
    #articleBody ul li strong:first-child {
      color: var(--text-primary, #efecfb);
    }

    /* === Conclusão === */
    #articleBody h2 {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--accent, #A855F7);
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border, #1C1C2E);
    }

    /* === Fontes === */
    #articleBody h2 + p,
    #articleBody h2 + ul {
      margin-top: 0.5rem;
    }
    #articleBody ul li a {
      color: var(--accent, #A855F7);
      text-decoration: none;
      transition: color 0.2s;
    }
    #articleBody ul li a:hover {
      color: #2ff801;
      text-decoration: underline;
    }

    /* === Headings in article body === */
    #articleBody h3 {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--text-primary, #efecfb);
      margin-top: 1.75rem;
      margin-bottom: 0.5rem;
    }

    @media (max-width: 640px) {
      #articleBody .product-card-body {
        padding: 1rem;
      }
      #articleBody .product-card-body h3 {
        font-size: 1.1rem;
      }
    }
  </style>
</Layout>

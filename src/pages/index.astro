---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/HeroSection.astro";
import ArticleCard from "../components/ArticleCard.astro";
import Sidebar from "../components/Sidebar.astro";

const artigos = Object.entries(import.meta.glob("../content/artigos/*.md", { eager: true }))
  .map(([path, mod]) => ({
    slug: path.split("/").pop()?.replace(".md", "") || "",
    ...mod.frontmatter,
    Content: mod.Content,
  }))
  .sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());

const [destaque, ...restante] = artigos;
const maisLidos = artigos.filter((a) => a.slug !== destaque?.slug);
---

<Layout title="Blog Gamer">
  <div class="pt-16 max-w-page mx-auto px-gutter">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl my-xl">
      <section class="lg:col-span-8 space-y-xl">
        {destaque && (
          <HeroSection
            title={destaque.title}
            description={destaque.description}
            pubDate={destaque.pubDate}
            tags={destaque.tags}
            category={destaque.category}
            affiliate={destaque.affiliate}
            slug={destaque.slug}
            image={destaque.image}
          />
        )}

        <div class="space-y-lg">
          <div class="flex items-center justify-between border-b border-outline-variant/30 pb-md">
            <h2 class="font-h2 text-h2 text-primary flex items-center gap-sm">
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">bolt</span>
              Latest News
            </h2>
            <a href={`${import.meta.env.BASE_URL || "/"}?categoria=hardware`} class="font-label text-label text-on-surface-variant hover:text-secondary transition-colors uppercase no-underline hover:no-underline">
              View All
            </a>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-lg">
            {restante.map((artigo) => (
              <ArticleCard
                title={artigo.title}
                description={artigo.description}
                pubDate={artigo.pubDate}
                tags={artigo.tags}
                category={artigo.category}
                affiliate={artigo.affiliate}
                slug={artigo.slug}
                image={artigo.image}
              />
            ))}
          </div>
        </div>
      </section>

      <aside class="lg:col-span-4">
        <Sidebar artigos={artigos} currentSlug={destaque?.slug} />
      </aside>
    </div>
  </div>

  {!destaque && (
    <div class="pt-16 max-w-page mx-auto px-gutter py-xxl">
      <section class="text-center py-xxl">
        <p style="font-size: 3rem; margin-bottom: 1rem;">&#x1F3AE;</p>
        <h1 class="font-h1 text-h1 mb-md">
          Bem-vindo ao <span class="text-primary">Blog Gamer</span>
        </h1>
        <p class="text-on-surface-variant text-lg max-w-lg mx-auto mb-lg">
          Notícias, reviews, listas e guias sobre o universo dos games.
        </p>
        <div class="flex gap-sm justify-center flex-wrap">
          <span class="inline-block bg-primary/10 text-primary border border-primary/20 rounded-full px-md py-xs font-label text-[0.65rem] uppercase tracking-widest">notícias</span>
          <span class="inline-block bg-primary/10 text-primary border border-primary/20 rounded-full px-md py-xs font-label text-[0.65rem] uppercase tracking-widest">reviews</span>
          <span class="inline-block bg-primary/10 text-primary border border-primary/20 rounded-full px-md py-xs font-label text-[0.65rem] uppercase tracking-widest">guias</span>
          <span class="inline-block bg-primary/10 text-primary border border-primary/20 rounded-full px-md py-xs font-label text-[0.65rem] uppercase tracking-widest">listas</span>
        </div>
      </section>
    </div>
  )}
</Layout>

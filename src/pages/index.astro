---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/HeroSection.astro";
import ArticleCard from "../components/ArticleCard.astro";

const artigos = Object.entries(import.meta.glob("../content/artigos/*.md", { eager: true }))
  .map(([path, mod]) => ({
    slug: path.split("/").pop()?.replace(".md", "") || "",
    ...mod.frontmatter,
    Content: mod.Content,
  }))
  .sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());

const [destaque, ...restante] = artigos;
---

<Layout title="Blog Gamer">
  {artigos.length === 0 && (
    <section class="hero" style="text-align: center;">
      <div class="hero-bg" />
      <div class="container">
        <div style="position: relative; z-index: 1; padding: 4rem 0;">
          <p style="font-size: 3rem; margin-bottom: 1rem;">🎮</p>
          <h1 style="font-size: 2rem; margin-bottom: 0.5rem;">
            Bem-vindo ao <span class="text-gradient">Blog Gamer</span>
          </h1>
          <p style="color: var(--text-secondary); font-size: 1.1rem; max-width: 600px; margin: 0 auto;">
            Notícias, reviews, listas e guias sobre o universo dos games — com os melhores links de afiliado pra você economizar.
          </p>
          <div style="display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap; margin-top: 1.5rem;">
            <span class="tag">notícias</span>
            <span class="tag">reviews</span>
            <span class="tag">guias de compra</span>
            <span class="tag">listas</span>
            <span class="tag">promoções</span>
          </div>
        </div>
      </div>
    </section>
  )}

  {destaque && (
    <HeroSection
      title={destaque.title}
      description={destaque.description}
      pubDate={destaque.pubDate}
      tags={destaque.tags}
      category={destaque.category}
      affiliate={destaque.affiliate}
      slug={destaque.slug}
    />
  )}

  {restante.length > 0 && (
    <section class="container" style="padding-bottom: 3rem;">
      <h2 class="section-title" style="margin-top: 0;">Últimos Artigos</h2>
      <div class="grid-3">
        {restante.map((artigo) => (
          <ArticleCard
            title={artigo.title}
            description={artigo.description}
            pubDate={artigo.pubDate}
            tags={artigo.tags}
            category={artigo.category}
            affiliate={artigo.affiliate}
            slug={artigo.slug}
            image={artigo.image}
          />
        ))}
      </div>
    </section>
  )}
</Layout>

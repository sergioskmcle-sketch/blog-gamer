---
import "../styles/global.css";
import "../styles/effects.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CursorEffect from "../components/CursorEffect.astro";
import SearchOverlay from "../components/SearchOverlay.astro";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  pubDate?: string;
  tags?: string[];
  category?: string;
  noindex?: boolean;
}

const { title, description, image, pubDate, tags, category, noindex } = Astro.props;
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
const canonicalPath = Astro.url.pathname.replace(/\/index\.html$/, "/").replace(/\/$/, "") + "/";
const canonicalURL = new URL(canonicalPath, Astro.site);

const searchArticles = Object.entries(import.meta.glob("../content/artigos/*.md", { eager: true }))
  .map(([path, mod]) => ({
    title: mod.frontmatter.title,
    url: `${base}blog/${path.split("/").pop()?.replace(".md", "")}/`,
    category: mod.frontmatter.category,
    tags: mod.frontmatter.tags || [],
    date: mod.frontmatter.pubDate ? new Date(mod.frontmatter.pubDate).toLocaleDateString("pt-BR") : "",
  }));
---

<!doctype html>
<html lang="pt-BR" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="kOOZLZ1vJ0aNnQUkmNDReiwSoYUJKZB0p-inN6ziszc" />
    <meta name="description" content={description || "Blog Gamer — notícias, reviews e guias do mundo dos games"} />
    <meta name="theme-color" content="#050505" />

    <link rel="canonical" href={canonicalURL.href} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description || "Blog sobre o mundo gamer"} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:type" content={pubDate ? "article" : "website"} />
    <meta property="og:site_name" content="Blog Gamer" />
    {image && (
      <>
        <meta property="og:image" content={image} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    )}
    <meta name="twitter:card" content="summary_large_image" />
    {image && <meta name="twitter:image" content={image} />}

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Public+Sans:wght@400;500;600;700;900&family=Orbitron:wght@700;900&display=swap&subset=latin" rel="stylesheet" />

    {pubDate && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        description,
        datePublished: pubDate,
        author: { "@type": "Person", name: "Blog Gamer" },
      })} />
    )}

    <title>{title} — Blog Gamer</title>
  </head>
  <body class="font-body selection:bg-primary selection:text-on-primary">
    <CursorEffect />
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
    <SearchOverlay />
    <script type="application/json" id="searchData" set:html={JSON.stringify(searchArticles)}></script>
  </body>
</html>

---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  pubDate?: string;
  tags?: string[];
  category?: string;
}

const { title, description, image, pubDate, tags, category } = Astro.props;
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || "Blog Gamer — notícias, reviews e guias do mundo dos games"} />
    <meta name="theme-color" content="#0a0a0f" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description || "Blog sobre o mundo gamer"} />
    <meta property="og:image" content={image || `${base}og-default.png`} />
    <meta property="og:type" content={pubDate ? "article" : "website"} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    {pubDate && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        description,
        datePublished: pubDate,
        author: { "@type": "Person", name: "Blog Gamer" },
      })} />
    )}

    <title>{title} — Blog Gamer</title>
  </head>
  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>

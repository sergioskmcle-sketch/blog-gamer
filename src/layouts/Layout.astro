---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  pubDate?: string;
  tags?: string[];
  category?: string;
}

const { title, description, image, pubDate, tags, category } = Astro.props;
const base = Astro.site?.pathname || "/";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || "Blog Gamer — notícias, reviews e guias do mundo dos games"} />
    <meta name="theme-color" content="#0a0a0f" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description || "Blog sobre o mundo gamer"} />
    <meta property="og:image" content={image || `${base}og-default.png`} />
    <meta property="og:type" content={pubDate ? "article" : "website"} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    {pubDate && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        description,
        datePublished: pubDate,
        author: { "@type": "Person", name: "Blog Gamer" },
      })} />
    )}

    <title>{title} — Blog Gamer</title>
  </head>
  <body>
    <div class="container">
      <header style="display: flex; align-items: center; justify-content: space-between; padding: 1.5rem 0; border-bottom: 1px solid var(--border); margin-bottom: 2rem;">
        <a href={base} style="font-size: 1.3rem; font-weight: 800; color: #fff; text-decoration: none; display: flex; align-items: center; gap: 0.5rem;">
          <span style="font-size: 1.6rem;">🎮</span> Blog Gamer
        </a>
        <nav style="display: flex; gap: 1.5rem; font-size: 0.9rem;">
          <a href={base} style="color: var(--text-secondary); text-decoration: none;">Início</a>
          <a href={base} style="color: var(--text-secondary); text-decoration: none;">Artigos</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer style="text-align: center; padding: 3rem 0 2rem; border-top: 1px solid var(--border); margin-top: 3rem; color: var(--text-muted); font-size: 0.85rem;">
        <p>Blog Gamer — Notícias, reviews e o melhor do mundo dos games</p>
        <p style="margin-top: 0.3rem;">Links podem conter afiliados. Ao comprar por eles, você apoia o blog.</p>
      </footer>
    </div>
  </body>
</html>

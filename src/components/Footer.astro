---
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
---

<footer class="w-full py-xxl bg-surface-container-lowest border-t border-outline-variant/30 mt-xxl">
  <div class="flex flex-col items-center gap-lg max-w-page mx-auto px-gutter">
    <a href={base} class="font-h2 text-h2 text-primary italic font-black tracking-tighter no-underline hover:no-underline hover:text-primary">
      Blog Gamer
    </a>

    <div class="flex flex-wrap justify-center gap-xl font-label text-label">
      <a href={`${base}`} class="text-on-surface-variant hover:text-primary transition-colors no-underline hover:no-underline">
        Início
      </a>
      <a href={`${base}?categoria=hardware`} class="text-on-surface-variant hover:text-primary transition-colors no-underline hover:no-underline">
        Hardware
      </a>
      <a href={`${base}?categoria=jogos`} class="text-on-surface-variant hover:text-primary transition-colors no-underline hover:no-underline">
        Jogos
      </a>
      <a href={`${base}?categoria=review`} class="text-on-surface-variant hover:text-primary transition-colors no-underline hover:no-underline">
        Reviews
      </a>
      <a href={`${base}?categoria=guia`} class="text-on-surface-variant hover:text-primary transition-colors no-underline hover:no-underline">
        Guias
      </a>
      <a href={`${base}?categoria=esports`} class="text-on-surface-variant hover:text-primary transition-colors no-underline hover:no-underline">
        eSports
      </a>
    </div>

    <p class="font-label text-label text-on-surface-variant/60 text-center">
      &copy; {new Date().getFullYear()} Blog Gamer. Tecnologia, jogos e cultura gamer.
    </p>

    <div class="flex gap-md pt-md">
      <a href={`${base}rss.xml`} class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center text-primary hover:bg-primary hover:text-on-primary transition-all no-underline hover:no-underline" title="RSS">
        <span class="material-symbols-outlined text-[20px]">rss_feed</span>
      </a>
      <a href={`mailto:?subject=${encodeURIComponent("Blog Gamer")}&body=${encodeURIComponent(base)}`} class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center text-primary hover:bg-primary hover:text-on-primary transition-all no-underline hover:no-underline" title="Compartilhar">
        <span class="material-symbols-outlined text-[20px]">share</span>
      </a>
    </div>

    <p class="font-label text-[10px] text-on-surface-variant/40 mt-md">
      Links podem conter afiliados — ao comprar por eles, você apoia o blog sem pagar nada a mais.
    </p>
  </div>
</footer>

---
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
---

<footer class="w-full py-xxl bg-background border-t border-outline-variant/30 mt-xxl">
  <div class="flex flex-col items-center justify-center gap-md px-margin-desktop max-w-page mx-auto text-center">
    <a href={base} class="font-black text-primary italic tracking-tighter text-xl no-underline hover:no-underline hover:text-primary">
      BLOG GAMER
    </a>

    <div class="flex gap-lg flex-wrap justify-center">
      <a href={base} class="font-label text-label text-on-surface-variant hover:text-on-surface transition-colors no-underline hover:no-underline">
        Início
      </a>
      <a href={`${base}blog/`} class="font-label text-label text-on-surface-variant hover:text-on-surface transition-colors no-underline hover:no-underline">
        Artigos
      </a>
      <a href={`${base}?categoria=noticia`} class="font-label text-label text-on-surface-variant hover:text-on-surface transition-colors no-underline hover:no-underline">
        Notícias
      </a>
      <a href={`${base}?categoria=review`} class="font-label text-label text-on-surface-variant hover:text-on-surface transition-colors no-underline hover:no-underline">
        Reviews
      </a>
      <a href={`${base}?categoria=guia`} class="font-label text-label text-on-surface-variant hover:text-on-surface transition-colors no-underline hover:no-underline">
        Guias
      </a>
      <a href={`${base}rss.xml`} class="font-label text-label text-on-surface-variant hover:text-on-surface transition-colors no-underline hover:no-underline">
        RSS
      </a>
    </div>

    <p class="font-label text-label text-on-surface-variant/60 max-w-md">
      &copy; {new Date().getFullYear()} Blog Gamer. Notícias, reviews e guias do universo dos games.
    </p>

    <div class="flex gap-md pt-md">
      <a href={`${base}rss.xml`} class="text-on-surface-variant hover:text-primary transition-all no-underline hover:no-underline" title="RSS Feed">
        <span class="material-symbols-outlined">rss_feed</span>
      </a>
      <a href="https://github.com/sergioskmcle-sketch/blog-gamer" target="_blank" rel="noopener" class="text-on-surface-variant hover:text-primary transition-all no-underline hover:no-underline" title="GitHub">
        <span class="material-symbols-outlined">code</span>
      </a>
      <a href={`mailto:?subject=${encodeURIComponent("Blog Gamer")}&body=${encodeURIComponent(base)}`} class="text-on-surface-variant hover:text-primary transition-all no-underline hover:no-underline" title="Compartilhar">
        <span class="material-symbols-outlined">share</span>
      </a>
    </div>

    <p class="font-label text-[10px] text-on-surface-variant/40 mt-md">
      Links podem conter afiliados — ao comprar por eles, você apoia o blog sem pagar nada a mais.
    </p>
  </div>
</footer>

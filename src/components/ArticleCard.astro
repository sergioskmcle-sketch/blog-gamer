---
export interface Props {
  title: string;
  description: string;
  pubDate: Date | string;
  tags?: string[];
  category?: string;
  affiliate?: boolean;
  slug: string;
  image?: string;
}

const { title, description, pubDate, tags, category, affiliate, slug, image } = Astro.props;
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");

const timeAgo = (date: Date | string) => {
  const now = new Date();
  const d = new Date(date);
  const diffMs = now.getTime() - d.getTime();
  const diffHrs = Math.floor(diffMs / 3600000);
  if (diffHrs < 1) return "Agora mesmo";
  if (diffHrs < 24) return `${diffHrs}h atrás`;
  const diffDays = Math.floor(diffHrs / 24);
  if (diffDays < 7) return `${diffDays}d atrás`;
  return d.toLocaleDateString("pt-BR");
};
---

<article class="card-depth overflow-hidden group cursor-pointer flex flex-col">
  <a href={`${base}blog/${slug}/`} class="no-underline hover:no-underline text-inherit flex flex-col flex-1">
    <div class="h-40 overflow-hidden relative">
      {image ? (
        <img
          src={image}
          alt={title}
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        />
      ) : (
        <div class="w-full h-full bg-[#1C1C2E] flex items-center justify-center text-4xl"></div>
      )}
      {category && (
        <span class="absolute top-3 left-3 px-3 py-1 rounded-full bg-primary text-on-primary font-label text-[10px] font-bold uppercase">
          {category}
        </span>
      )}
    </div>

    <div class="p-md space-y-sm flex flex-col flex-1">
      <h3 class="font-h2 text-[1.1rem] leading-snug group-hover:text-primary transition-colors line-clamp-2">
        {title}
      </h3>

      <p class="text-on-surface-variant text-sm line-clamp-3">
        {description}
      </p>

      <div class="flex items-center justify-between font-label text-[11px] text-outline pt-sm border-t border-outline-variant/20 mt-auto">
        <span>{timeAgo(pubDate)}</span>
        <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 0, 'wght' 300">bookmark</span>
      </div>
    </div>
  </a>
</article>

---
export interface Props {
  title: string;
  description: string;
  pubDate: Date | string;
  tags?: string[];
  category?: string;
  affiliate?: boolean;
  slug: string;
  image?: string;
}

const { title, description, pubDate, tags, category, affiliate, slug, image } = Astro.props;
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
const date = new Date(pubDate).toLocaleDateString("pt-BR");

const readingTime = Math.max(1, Math.ceil((description || "").split(" ").length / 200));

const categoryIcons: Record<string, string> = {
  noticia: "📰",
  review: "⭐",
  guia: "📖",
  lista: "📋",
  promocao: "🏷️",
};
---

<article class="group bg-surface-container-low border border-outline-variant/10 rounded-xl overflow-hidden transition-all duration-300 card-glow flex flex-col">
  <a href={`${base}blog/${slug}/`} class="no-underline hover:no-underline text-inherit flex flex-col flex-1">
    <div class="aspect-video overflow-hidden">
      {image ? (
        <img
          src={image}
          alt={title}
          loading="lazy"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
      ) : (
        <div class="w-full h-full bg-surface-container-higher flex items-center justify-center text-4xl">
          {categoryIcons[category?.toLowerCase()] || "🎮"}
        </div>
      )}
    </div>

    <div class="p-md flex flex-col flex-grow">
      <div class="flex items-center gap-sm mb-sm">
        {category && (
          <span class="text-primary font-label text-[10px] uppercase">
            {category}
          </span>
        )}
        {affiliate && (
          <span class="text-warning font-label text-[10px] uppercase">
            🔗 afiliado
          </span>
        )}
      </div>

      <h3 class="font-h2 text-xl text-on-surface mb-sm group-hover:text-primary transition-colors">
        {title}
      </h3>

      <p class="text-on-surface-variant text-sm line-clamp-3 mb-md">
        {description}
      </p>

      {tags && tags.length > 0 && (
        <div class="flex gap-xs flex-wrap mb-md">
          {tags.slice(0, 3).map((tag) => (
            <span class="text-[10px] text-on-surface-variant font-label bg-surface-container-high px-2 py-0.5 rounded">
              {tag}
            </span>
          ))}
        </div>
      )}

      <div class="mt-auto flex items-center justify-between pt-md border-t border-outline-variant/10">
        <span class="text-on-tertiary-fixed-variant text-[10px] font-label">{readingTime} MIN DE LEITURA</span>
        <span class="material-symbols-outlined text-primary text-sm group-hover:translate-x-1 transition-transform">trending_flat</span>
      </div>
    </div>
  </a>
</article>

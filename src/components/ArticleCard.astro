---
export interface Props {
  title: string;
  description: string;
  pubDate: Date | string;
  tags?: string[];
  category?: string;
  affiliate?: boolean;
  slug: string;
  image?: string;
}

const { title, description, pubDate, tags, category, affiliate, slug, image } = Astro.props;
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");

const date = new Date(pubDate).toLocaleDateString("pt-BR");

const categoryIcons: Record<string, string> = {
  noticia: "📰",
  review: "⭐",
  guia: "📖",
  lista: "📋",
  promocao: "🏷️",
};
---

<article class="card article-card">
  <a href={`${base}blog/${slug}/`} class="article-link">
    <div class="card-image">
      {image ? (
        <img src={image} alt={title} loading="lazy" />
      ) : (
        <span>{categoryIcons[category?.toLowerCase()] || "🎮"}</span>
      )}
    </div>
    <div class="card-body">
      <div class="card-tags">
        {category && (
          <span class="tag tag-secondary">{category}</span>
        )}
        {affiliate && (
          <span class="tag tag-warning">🔗 afiliado</span>
        )}
      </div>
      <h2 class="card-title">{title}</h2>
      <p class="card-desc">{description}</p>
      <div class="card-tags" style="margin-top: 0.5rem;">
        {tags?.slice(0, 3).map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </div>
  </a>
  <div class="card-footer">
    <time style="font-size: 0.8rem; color: var(--text-muted);">{date}</time>
    <span style="font-size: 0.75rem; color: var(--accent); font-weight: 500;">Ler artigo →</span>
  </div>
</article>

<style is:global>
  .article-card {
    overflow: hidden;
    padding: 0;
    display: flex;
    flex-direction: column;
    transition: all var(--transition);
  }

  .article-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-glow);
    transform: translateY(-3px);
  }

  .article-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .article-link:hover {
    text-decoration: none;
    color: inherit;
  }

  .article-card:hover .card-image {
    transform: scale(1.03);
  }

  .card-image {
    transition: transform var(--transition-slow);
  }
</style>

---
export interface Artigo {
  title: string;
  slug: string;
  pubDate: Date | string;
  category?: string;
  image?: string;
}

const { artigos, currentSlug }: { artigos: Artigo[]; currentSlug?: string } = Astro.props;
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
const recentes = artigos.filter((a) => a.slug !== currentSlug).slice(0, 5);

const categories = [
  { name: "Notícias", slug: "noticia", count: artigos.filter((a) => a.category === "noticia").length },
  { name: "Reviews", slug: "review", count: artigos.filter((a) => a.category === "review").length },
  { name: "Guias", slug: "guia", count: artigos.filter((a) => a.category === "guia" || a.category === "lista").length },
  { name: "Promoções", slug: "promocao", count: artigos.filter((a) => a.category === "promocao").length },
];
---

<aside class="w-full lg:w-80 shrink-0 space-y-xl">
  <div class="bg-surface-container-low border border-outline-variant/10 p-lg rounded-xl">
    <h4 class="font-label text-label text-on-surface border-b border-outline-variant/20 pb-sm mb-md flex items-center gap-sm">
      <span class="material-symbols-outlined text-sm">category</span>
      CATEGORIAS
    </h4>
    <div class="flex flex-col gap-xs">
      {categories.map((cat) => (
        <a
          href={`${base}?categoria=${cat.slug}`}
          class="flex items-center justify-between p-sm hover:bg-surface-container rounded transition-colors group no-underline hover:no-underline"
        >
          <span class="text-on-surface-variant group-hover:text-primary transition-colors text-sm">{cat.name}</span>
          <span class="text-[10px] font-label bg-surface-container-high px-2 py-0.5 rounded text-on-surface-variant">{cat.count}</span>
        </a>
      ))}
    </div>
  </div>

  <div class="bg-surface-container-low border border-outline-variant/10 p-lg rounded-xl">
    <h4 class="font-label text-label text-on-surface border-b border-outline-variant/20 pb-sm mb-md flex items-center gap-sm">
      <span class="material-symbols-outlined text-sm">bolt</span>
      ÚLTIMOS ARTIGOS
    </h4>
    <div class="space-y-md">
      {recentes.length === 0 && (
        <p class="text-on-surface-variant text-xs">Nenhum artigo publicado ainda.</p>
      )}
      {recentes.map((artigo) => (
        <a
          href={`${base}blog/${artigo.slug}/`}
          class="flex gap-md group cursor-pointer no-underline hover:no-underline"
        >
          <div class="w-16 h-16 bg-surface-container rounded overflow-hidden shrink-0">
            {artigo.image ? (
              <div
                class="w-full h-full bg-cover bg-center"
                style="background-image: url('{artigo.image}')"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-lg">
                🎮
              </div>
            )}
          </div>
          <div class="flex-1 min-w-0">
            <h5 class="text-xs font-semibold text-on-surface group-hover:text-primary transition-colors line-clamp-2">
              {artigo.title}
            </h5>
            <span class="text-[9px] text-on-surface-variant uppercase mt-1 block">
              {new Date(artigo.pubDate).toLocaleDateString("pt-BR")}
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="relative overflow-hidden bg-primary p-lg rounded-xl">
    <div class="absolute -right-8 -top-8 w-32 h-32 bg-on-primary-container/20 rounded-full blur-2xl" />
    <div class="relative z-10">
      <h4 class="font-h2 text-lg text-on-primary mb-xs">Newsletter</h4>
      <p class="text-on-primary/80 text-xs mb-md">
        Receba as melhores notícias direto no seu email.
      </p>
      <div class="space-y-sm">
        <input
          class="w-full bg-on-primary/10 border border-on-primary/30 text-on-primary placeholder:text-on-primary/50 text-xs rounded-lg px-md py-xs outline-none focus:ring-1 focus:ring-on-primary"
          placeholder="Seu email"
          type="email"
        />
        <button class="w-full bg-on-primary text-primary py-sm rounded-lg font-label text-[10px] hover:bg-on-primary/90 transition-all uppercase tracking-widest">
          INSCREVER
        </button>
      </div>
    </div>
  </div>
</aside>

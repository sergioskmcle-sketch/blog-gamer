---
export interface Artigo {
  title: string;
  slug: string;
  pubDate: Date | string;
  category?: string;
}

const { artigos, currentSlug }: { artigos: Artigo[]; currentSlug?: string } = Astro.props;
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
const recentes = artigos.filter((a) => a.slug !== currentSlug).slice(0, 5);
---

<aside class="sidebar-content">
  <div class="sidebar-section card">
    <h3 class="sidebar-title">📌 Em Destaque</h3>
    <div class="affiliate-spotlight">
      <p>Melhores ofertas em games e periféricos.</p>
      <div class="affiliate-links">
        <a href="https://mercadolivre.com.br" target="_blank" rel="noopener" class="affiliate-btn">
          🛒 Mercado Livre
        </a>
        <a href="https://shopee.com.br" target="_blank" rel="noopener" class="affiliate-btn">
          🛒 Shopee
        </a>
      </div>
      <p class="affiliate-note">Links de afiliado ajudam o blog</p>
    </div>
  </div>

  <div class="sidebar-section card">
    <h3 class="sidebar-title">⚡ Últimos Artigos</h3>
    <ul class="recent-list">
      {recentes.length === 0 && (
        <li class="recent-empty">Nenhum artigo publicado ainda.</li>
      )}
      {recentes.map((artigo) => (
        <li>
          <a href={`${base}blog/${artigo.slug}/`} class="recent-item">
            <span class="recent-category">{artigo.category || "artigo"}</span>
            <span class="recent-title">{artigo.title}</span>
            <time class="recent-date">{new Date(artigo.pubDate).toLocaleDateString("pt-BR")}</time>
          </a>
        </li>
      ))}
    </ul>
  </div>
</aside>

<style is:global>
  .sidebar-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-section {
    padding: 1.25rem;
  }

  .sidebar-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .sidebar-title::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .affiliate-spotlight p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .affiliate-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .affiliate-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    background: var(--accent-dim);
    border: 1px solid rgba(0, 255, 136, 0.15);
    border-radius: var(--radius-sm);
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 600;
    transition: all var(--transition);
    text-decoration: none;
  }

  .affiliate-btn:hover {
    background: rgba(0, 255, 136, 0.15);
    box-shadow: 0 0 15px var(--accent-glow);
    text-decoration: none;
  }

  .affiliate-note {
    font-size: 0.7rem !important;
    color: var(--text-muted) !important;
    margin: 0.75rem 0 0 !important;
    text-align: center;
  }

  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .recent-list li {
    margin: 0;
  }

  .recent-empty {
    font-size: 0.85rem;
    color: var(--text-muted);
    padding: 0.5rem 0;
  }

  .recent-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.6rem 0.75rem;
    border-radius: var(--radius-sm);
    transition: all var(--transition);
    text-decoration: none;
  }

  .recent-item:hover {
    background: var(--accent-dim);
    text-decoration: none;
  }

  .recent-category {
    font-size: 0.7rem;
    color: var(--accent);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .recent-title {
    font-size: 0.85rem;
    color: var(--text-primary);
    font-weight: 500;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .recent-date {
    font-size: 0.75rem;
    color: var(--text-muted);
  }
</style>

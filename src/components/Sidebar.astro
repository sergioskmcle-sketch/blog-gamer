---
export interface Artigo {
  title: string;
  slug: string;
  pubDate: Date | string;
  category?: string;
  image?: string;
}

const { artigos, currentSlug }: { artigos: Artigo[]; currentSlug?: string } = Astro.props;
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");

const recentes = artigos.filter((a) => a.slug !== currentSlug).slice(0, 10);

const categories = [
  { name: "Hardware", slug: "hardware", icon: "memory", count: artigos.filter((a) => a.category === "hardware").length },
  { name: "Games", slug: "jogos", icon: "sports_esports", count: artigos.filter((a) => a.category === "jogos" || a.category === "noticia").length },
  { name: "eSports", slug: "esports", icon: "trophy", count: artigos.filter((a) => a.category === "esports").length },
  { name: "Reviews", slug: "review", icon: "grade", count: artigos.filter((a) => a.category === "review").length },
  { name: "Guias", slug: "guia", icon: "menu_book", count: artigos.filter((a) => a.category === "guia" || a.category === "lista").length },
];
---

<aside class="space-y-xxl">
  <div class="card-depth p-md sticky top-24">
    <div class="mb-lg">
      <h3 class="font-h2 text-[1.25rem] text-primary flex items-center gap-sm">
        <span class="material-symbols-outlined">trending_up</span>
        Popular This Week
      </h3>
      <p class="font-body text-sm text-on-surface-variant mt-xs">Blog Gamer</p>
    </div>

    <ul class="space-y-md">
      {recentes.length === 0 && <li class="text-on-surface-variant text-xs">Nenhum artigo publicado ainda.</li>}
      {recentes.slice(0, 4).map((artigo, idx) => (
        <li class="flex gap-md items-start group cursor-pointer">
          <a href={`${base}blog/${artigo.slug}/`} class="flex gap-md items-start no-underline hover:no-underline w-full">
            <span class="font-h1 text-h2 text-outline-variant group-hover:text-primary transition-colors shrink-0">
              {String(idx + 1).padStart(2, "0")}
            </span>
            <div>
              <h4 class="font-h2 text-sm leading-tight text-on-surface group-hover:text-primary transition-colors">
                {artigo.title}
              </h4>
              <span class="font-label text-[10px] text-outline uppercase tracking-wider">
                {artigo.category || "Artigo"}
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>

    <hr class="my-lg border-outline-variant/20" />

    <a
      href="https://t.me/+TRWZ67WHuk85Y2Nh"
      target="_blank"
      rel="noopener noreferrer"
      class="block p-md rounded-lg card-depth group no-underline hover:no-underline relative overflow-hidden"
    >
      <div class="absolute inset-0 bg-gradient-to-br from-[#2AABEE]/10 via-transparent to-[#229ED9]/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
      <div class="relative">
        <div class="flex items-center gap-sm mb-sm">
          <svg class="w-5 h-5 text-[#2AABEE]" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"/>
          </svg>
          <p class="font-label text-[10px] uppercase text-[#2AABEE] tracking-widest font-bold">Grupo VIP</p>
        </div>
        <h4 class="font-h2 text-sm mb-xs text-on-background group-hover:text-[#2AABEE] transition-colors leading-snug">
          Ofertas Gamer Diárias
        </h4>
        <p class="font-body text-xs text-on-surface-variant leading-relaxed">
          Nosso grupo vasculha a internet em busca das melhores promoções de produtos gamers. Dezenas de ofertas todos os dias.
        </p>
        <span class="inline-flex items-center gap-xs mt-sm font-label text-[10px] uppercase tracking-widest text-[#2AABEE] font-bold group-hover:gap-md transition-all">
          Entrar no Grupo
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </span>
      </div>
    </a>

    <div class="space-y-md">
      <h3 class="font-label text-label uppercase tracking-[0.2em] text-outline-variant">Categorias</h3>
      <div class="grid grid-cols-1 gap-sm">
        {categories.map((cat) => (
          <a
            href={`${base}?categoria=${cat.slug}`}
            class="flex items-center justify-between p-sm rounded-lg btn-depth hover:border-primary/30 hover:text-primary transition-all group no-underline hover:no-underline"
          >
            <span class="flex items-center gap-xs font-body text-on-surface">
              <span class="material-symbols-outlined text-secondary">{cat.icon}</span>
              {cat.name}
            </span>
            <span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-opacity">chevron_right</span>
          </a>
        ))}
      </div>
    </div>

    <div class="mt-xl p-md rounded-lg card-depth">
      <p class="font-label text-[10px] uppercase text-primary mb-sm tracking-widest">Conteúdo Exclusivo</p>
      <h4 class="font-h2 text-sm mb-md text-on-background">Inscreva-se na nossa newsletter editorial para análises toda semana.</h4>
      <form id="newsletterForm">
        <input
          id="newsletterInput"
          type="email"
          required
          placeholder="Seu email"
          class="w-full py-sm px-md rounded-md bg-surface-container-low border border-outline-variant/30 text-on-surface text-sm placeholder:text-outline/50 mb-sm focus:outline-none focus:border-primary"
        />
        <button type="submit" id="newsletterBtn" class="w-full py-sm bg-primary text-on-primary font-label text-[10px] uppercase font-bold rounded-md hover:opacity-90 transition-opacity">
          Inscrever
        </button>
        <p id="newsletterFeedback" class="text-[10px] text-primary/70 mt-xs hidden"></p>
      </form>
    </div>
  </div>
</aside>

<script>
  const form = document.getElementById("newsletterForm");
  const input = document.getElementById("newsletterInput");
  const btn = document.getElementById("newsletterBtn");
  const feedback = document.getElementById("newsletterFeedback");

  if (form) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      if (input && input.value.trim()) {
        btn.textContent = "INSCRITO!";
        btn.disabled = true;
        btn.style.opacity = "0.6";
        feedback.textContent = "Obrigado por se inscrever!";
        feedback.classList.remove("hidden");
        input.value = "";
      }
    });
  }
</script>

---
export interface Props {
  title: string;
  description: string;
  pubDate: Date | string;
  tags?: string[];
  category?: string;
  affiliate?: boolean;
  slug: string;
  image?: string;
}

const { title, description, pubDate, tags, category, affiliate, slug, image } = Astro.props;
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
const date = new Date(pubDate).toLocaleDateString("pt-BR");
---

<section class="relative rounded-xl overflow-hidden mb-xxl group">
  <div class="h-[400px] md:h-[600px] w-full relative">
    <div
      class="absolute inset-0 w-full h-full bg-cover bg-center transition-transform duration-700 group-hover:scale-105"
      style="background-image: url('{image || `${base}hero-default.jpg`}')"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-[#050505]/40 to-transparent"></div>
  </div>
  <div class="absolute bottom-0 left-0 p-lg md:p-xxl max-w-2xl">
    {category && (
      <span class="inline-block bg-electric-purple text-white px-md py-xs rounded-full font-label text-[0.65rem] uppercase tracking-widest mb-md">
        {category}
      </span>
    )}
    <h1 class="font-h1 text-h1 text-white mb-md halo-glow leading-tight">
      {title}
    </h1>
    <div class="flex items-center gap-md text-on-surface-variant mb-lg font-label">
      <span class="flex items-center gap-xs">
        <span class="material-symbols-outlined text-[18px]">person</span>
        Blog Gamer
      </span>
      <span class="w-1 h-1 bg-outline rounded-full"></span>
      <span>{date}</span>
    </div>
    <a
      href={`${base}blog/${slug}/`}
      class="inline-flex items-center gap-sm bg-neon-green text-[#050505] px-xl py-md rounded-lg font-bold neon-glow transition-all active:scale-95 no-underline hover:no-underline hover:text-[#050505]"
    >
      Ler Matéria
      <span class="material-symbols-outlined">arrow_forward</span>
    </a>
  </div>
</section>

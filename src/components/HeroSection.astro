---
export interface Props {
  title: string;
  description: string;
  pubDate: Date | string;
  tags?: string[];
  category?: string;
  affiliate?: boolean;
  slug: string;
  image?: string;
}

const { title, description, pubDate, tags, category, affiliate, slug, image } = Astro.props;
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
const date = new Date(pubDate).toLocaleDateString("pt-BR", { timeZone: "UTC" }).toUpperCase();
const bgImage = image || `${base}hero-default.jpg`;
---

<section class="relative group overflow-hidden rounded-xl bg-surface-container-low h-[500px] flex flex-col justify-end shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_4px_24px_rgba(0,0,0,0.6)]">
  <div class="absolute inset-0 z-0">
    <div
      class="w-full h-full bg-cover bg-center transition-transform duration-700 group-hover:scale-105"
      style={{ backgroundImage: `url('${bgImage}')` }}
    />
    <div class="absolute inset-0 carbon-overlay"></div>
  </div>
  <div class="relative z-10 p-xl space-y-md">
    {category && (
      <span class="inline-block px-md py-1 rounded-full bg-surface-container-high/80 border border-white/10 text-primary font-label text-label uppercase tracking-widest shadow-[inset_0_1px_0_rgba(255,255,255,0.08),0_1px_3px_rgba(0,0,0,0.5)]">
        {category}
      </span>
    )}
    <h1 class="font-h1 text-h1 text-white max-w-2xl leading-tight text-emboss">
      {title}
    </h1>
    <div class="flex items-center gap-md font-label text-label text-outline-variant uppercase tracking-widest">
      <span class="text-outline-variant">Blog Gamer</span>
      <span class="w-1 h-1 bg-outline-variant rounded-full"></span>
      <span class="text-outline-variant">{date}</span>
    </div>
    <a
      href={`${base}blog/${slug}/`}
      class="btn-depth inline-flex items-center gap-xs mt-md px-xl py-md text-primary font-label text-label uppercase tracking-widest font-bold no-underline hover:no-underline hover:text-primary active:scale-95"
    >
      Ler Matéria
      <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
    </a>
  </div>
</section>

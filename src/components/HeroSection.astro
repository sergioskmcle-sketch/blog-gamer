---
export interface Props {
  title: string;
  description: string;
  pubDate: Date | string;
  tags?: string[];
  category?: string;
  affiliate?: boolean;
  slug: string;
  image?: string;
}

const { title, description, pubDate, tags, category, affiliate, slug, image } = Astro.props;
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
const date = new Date(pubDate).toLocaleDateString("pt-BR", { timeZone: "UTC" }).toUpperCase();
---

<section class="relative group overflow-hidden rounded-xl border border-outline-variant/20 bg-surface-container-low shadow-2xl h-[500px] flex flex-col justify-end">
  <div class="absolute inset-0 z-0">
    <div
      class="w-full h-full bg-cover bg-center transition-transform duration-700 group-hover:scale-105"
      style="background-image: url('{image || `${base}hero-default.jpg`}')"
    />
    <div class="absolute inset-0 carbon-overlay"></div>
  </div>
  <div class="relative z-10 p-xl space-y-md">
    <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-96 h-96 hero-glow opacity-50 pointer-events-none"></div>
    {category && (
      <span class="inline-block px-md py-1 rounded-full bg-primary/20 border border-primary/30 text-primary font-label text-label uppercase tracking-widest">
        {category}
      </span>
    )}
    <h1 class="font-h1 text-h1 text-white drop-shadow-lg max-w-2xl leading-tight">
      {title}
    </h1>
    <div class="flex items-center gap-md font-label text-label text-outline-variant uppercase tracking-widest">
      <span class="text-outline-variant">Blog Gamer</span>
      <span class="w-1 h-1 bg-outline-variant rounded-full"></span>
      <span class="text-outline-variant">{date}</span>
    </div>
    <a
      href={`${base}blog/${slug}/`}
      class="inline-flex items-center gap-xs mt-md px-xl py-md bg-secondary text-on-secondary font-label text-label uppercase tracking-widest font-bold rounded-lg transition-all hover:shadow-[0_0_20px_rgba(57,255,20,0.4)] active:scale-95 no-underline hover:no-underline hover:text-on-secondary"
    >
      Ler Matéria
      <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
    </a>
  </div>
</section>
